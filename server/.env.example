# Server
PORT=8080

# PowerSync instance URL (from your PowerSync dashboard)
POWERSYNC_URL=https://your-instance.powersync.journeyapps.com

# Database
DATABASE_URI=postgres://user:password@localhost:5432/mydb

# JWT Keys (RS256)
# Generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
# Then base64-encode each: base64 -i private.pem
POWERSYNC_PRIVATE_KEY_BASE64=
POWERSYNC_PUBLIC_KEY_BASE64=

# A stable key ID (any unique string, e.g. a UUID)
POWERSYNC_KEY_ID=my-key-id-001

# Development mode: set to "true" to use a development token (no real keys needed)
# Do NOT use in production
DEV_MODE=false
